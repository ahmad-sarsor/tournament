{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/display/**",
              "components/match/**",
              "components/standings/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo Bhaijaan 2|Tajawal))/i]",
        "message": "Font not provided by the design system. Available: Baloo Bhaijaan 2, Tajawal."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: status, children, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:upcoming|active|finished|live|gold)$/]",
        "message": "<Badge> status must be one of 'upcoming' | 'active' | 'finished' | 'live' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BracketMatch'] > JSXAttribute > JSXIdentifier[name!=/^(?:home|away|hs|as|status|key|ref|className|style|children)$/]",
        "message": "<BracketMatch> doesn't accept that prop. Declared props: home, away, hs, as, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='BracketMatch'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:scheduled|live|finished)$/]",
        "message": "<BracketMatch> status must be one of 'scheduled' | 'live' | 'finished'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|disabled|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, disabled, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|sun|outline|danger)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'sun' | 'outline' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm)$/]",
        "message": "<Button> size must be one of 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormGuide'] > JSXAttribute > JSXIdentifier[name!=/^(?:results|key|ref|className|style|children)$/]",
        "message": "<FormGuide> doesn't accept that prop. Declared props: results."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|group|homeName|awayName|homeScore|awayScore|status|onClick|key|ref|className|style|children)$/]",
        "message": "<MatchRow> doesn't accept that prop. Declared props: time, group, homeName, awayName, homeScore, awayScore, status, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatchRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:scheduled|live|finished)$/]",
        "message": "<MatchRow> status must be one of 'scheduled' | 'live' | 'finished'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Scoreboard'] > JSXAttribute > JSXIdentifier[name!=/^(?:homeName|awayName|homeScore|awayScore|live|minute|time|homeEmoji|awayEmoji|key|ref|className|style|children)$/]",
        "message": "<Scoreboard> doesn't accept that prop. Declared props: homeName, awayName, homeScore, awayScore, live, minute, time, homeEmoji, awayEmoji."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: options, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='StandingRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|name|played|won|drawn|lost|gf|ga|gd|points|form|key|ref|className|style|children)$/]",
        "message": "<StandingRow> doesn't accept that prop. Declared props: rank, name, played, won, drawn, lost, gf, ga, gd, points, form."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|label|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: icon, value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|onChange|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: items, active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: kind, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:ok|err)$/]",
        "message": "<Toast> kind must be one of 'ok' | 'err'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TournamentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|emoji|description|status|meta|done|total|onClick|key|ref|className|style|children)$/]",
        "message": "<TournamentCard> doesn't accept that prop. Declared props: name, emoji, description, status, meta, done, total, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='TournamentCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:upcoming|active|finished)$/]",
        "message": "<TournamentCard> status must be one of 'upcoming' | 'active' | 'finished'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
