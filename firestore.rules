rules_version = '2';

// ============================================================================
//  قواعد أمان Firestore — نموذج متعدّد المستأجرين
//  الأدوار:
//   • المالك (owner): مثبَّت أدناه. كل الصلاحيات + اعتماد الأعضاء ومنح مدراء المنصّة.
//   • مدير منصّة (platform admin): في admins/{email} — يعدّل كل التورنيرات. يمنحه المالك.
//   • عضو معتمَد (member): في members/{email} — يُنشئ تورنيرات ويملكها. يعتمده المالك.
//   • مدير تورنير: بريده في admin_emails للتورنير — يعدّل ذلك التورنير فقط.
//   القراءة عامّة (عرض للزوّار). النشر: Firebase Console → Firestore → Rules → Publish
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ✍️ بريد/بُرد «المالك»
    function ownerEmails() { return ['ahmad.kefah11sar@gmail.com']; }

    function uemail() { return request.auth != null ? request.auth.token.email : null; }
    function isOwner() { return uemail() != null && uemail() in ownerEmails(); }
    function isPlatformAdmin() {
      return isOwner()
        || (uemail() != null && exists(/databases/$(database)/documents/admins/$(uemail())));
    }
    function isMember() {
      return isPlatformAdmin()
        || (uemail() != null && exists(/databases/$(database)/documents/members/$(uemail())));
    }

    // صلاحية التعديل داخل تورنير معطى (بمعطياته d): منصّة، أو مالكه، أو مدير معيّن فيه
    function canEditT(d) {
      return isPlatformAdmin()
        || (uemail() != null && (d.owner_email == uemail()
            || (d.admin_emails is list && uemail().lower() in d.admin_emails)));
    }
    function tData(tid) {
      return get(/databases/$(database)/documents/tournaments/$(tid)).data;
    }
    function parentAllows(tid) {
      return exists(/databases/$(database)/documents/tournaments/$(tid)) && canEditT(tData(tid));
    }

    // اقتراح صالح للإضافة من الزائر (بلا تسجيل)
    function isValidSuggestion() {
      let d = request.resource.data;
      return d.keys().hasOnly(['text', 'name', 'context', 'created_at'])
        && d.text is string && d.text.size() >= 1 && d.text.size() <= 1000
        && (!('name' in d)    || (d.name is string && d.name.size() <= 80))
        && (!('context' in d) || (d.context is string && d.context.size() <= 200))
        && (!('created_at' in d) || d.created_at is number);
    }

    // ---- البطولات ----------------------------------------------------------
    match /tournaments/{id} {
      allow read: if true;
      // ينشئها عضو معتمَد ويضع نفسه مالكاً
      allow create: if isMember() && request.resource.data.owner_email == uemail();
      // التعديل: من له صلاحية داخلها؛ لا يتغيّر المالك، وقائمة مدراء التورنير
      // لا يعدّلها إلا المالك/مدير المنصّة (لا مدير التورنير)
      allow update: if canEditT(resource.data)
        && request.resource.data.owner_email == resource.data.owner_email
        && (request.resource.data.get('admin_emails', []) == resource.data.get('admin_emails', [])
            || isPlatformAdmin() || resource.data.owner_email == uemail());
      // الحذف: مالك التورنير أو منصّة فقط
      allow delete: if isPlatformAdmin() || (uemail() != null && resource.data.owner_email == uemail());
    }

    // ---- بيانات التورنير: تُقيَّد بصلاحية التورنير الأب (عبر tournament_id) ----
    match /groups/{id} {
      allow read: if true;
      allow create: if parentAllows(request.resource.data.tournament_id);
      allow update: if parentAllows(resource.data.tournament_id)
        && request.resource.data.tournament_id == resource.data.tournament_id;
      allow delete: if parentAllows(resource.data.tournament_id);
    }
    match /teams/{id} {
      allow read: if true;
      allow create: if parentAllows(request.resource.data.tournament_id);
      allow update: if parentAllows(resource.data.tournament_id)
        && request.resource.data.tournament_id == resource.data.tournament_id;
      allow delete: if parentAllows(resource.data.tournament_id);
    }
    match /matches/{id} {
      allow read: if true;
      allow create: if parentAllows(request.resource.data.tournament_id);
      allow update: if parentAllows(resource.data.tournament_id)
        && request.resource.data.tournament_id == resource.data.tournament_id;
      allow delete: if parentAllows(resource.data.tournament_id);
    }
    match /players/{id} {
      allow read: if true;
      allow create: if parentAllows(request.resource.data.tournament_id);
      allow update: if parentAllows(resource.data.tournament_id)
        && request.resource.data.tournament_id == resource.data.tournament_id;
      allow delete: if parentAllows(resource.data.tournament_id);
    }
    match /events/{id} {
      allow read: if true;
      allow create: if parentAllows(request.resource.data.tournament_id);
      allow update: if parentAllows(resource.data.tournament_id)
        && request.resource.data.tournament_id == resource.data.tournament_id;
      allow delete: if parentAllows(resource.data.tournament_id);
    }

    // ---- صندوق الاقتراحات ---------------------------------------------------
    match /suggestions/{id} {
      allow create: if isValidSuggestion();
      allow read, delete: if isPlatformAdmin();
      allow update: if false;
    }

    // ---- المسجّلون: كل مستخدم ينشئ وثيقته؛ مدراء المنصّة يقرؤون القائمة --------
    match /users/{uid} {
      allow read: if isPlatformAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['email', 'name', 'created_at'])
        && request.resource.data.email == uemail()
        && request.resource.data.name is string && request.resource.data.name.size() <= 60;
      allow delete: if isOwner();
    }

    // ---- الأعضاء المعتمَدون (يُنشئون تورنيرات) — المالك وحده يعتمد -------------
    match /members/{addr} {
      allow read: if isPlatformAdmin() || (uemail() != null && uemail() == addr);
      allow write: if isOwner();
    }

    // ---- مدراء المنصّة (كل الصلاحيات) — المالك وحده يمنح ----------------------
    match /admins/{addr} {
      allow read: if isPlatformAdmin() || (uemail() != null && uemail() == addr);
      allow write: if isOwner();
    }

    // أي مجموعة أخرى: ممنوعة افتراضياً
    match /{document=**} { allow read, write: if false; }
  }
}
