rules_version = '2';

// ============================================================================
//  قواعد أمان Firestore
//  القراءة متاحة للجميع (عرض عام). الكتابة متاحة فقط لحساب/حسابات المدير.
//
//  ⚠️ مهم جداً: ضع بريد المدير في القائمة أدناه (نفس البريد الذي أنشأته في
//  Firebase Authentication). بدون ذلك لن يستطيع أحد التعديل — وبِقيمة خاطئة
//  قد يتمكّن أي مستخدم مسجَّل من التعديل. لا تكتفِ بـ (request.auth != null).
//
//  انسخ هذا الملف إلى: Firebase Console → Firestore Database → Rules → Publish
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ✍️ بريد/بُرد «المالك»: الوحيد القادر على تعيين/إزالة المدراء (super-admin)
    function ownerEmails() {
      return ['ahmad.kefah11sar@gmail.com'];
    }

    function isOwner() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in ownerEmails();
    }

    // مدير = المالك، أو بريده مُسجَّل في مجموعة admins (يعيّنه المالك من لوحة الإدارة)
    function isAdmin() {
      return isOwner()
        || (request.auth != null && request.auth.token.email != null
            && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // اقتراح صالح للإضافة من الزائر (بلا تسجيل): نص إلزامي ومحدود الطول،
    // ولا يُسمح إلا بالحقول المعروفة (منعاً للعبث).
    function isValidSuggestion() {
      let d = request.resource.data;
      return d.keys().hasOnly(['text', 'name', 'context', 'created_at'])
        && d.text is string && d.text.size() >= 1 && d.text.size() <= 1000
        && (!('name' in d)    || (d.name is string && d.name.size() <= 80))
        && (!('context' in d) || (d.context is string && d.context.size() <= 200))
        && (!('created_at' in d) || d.created_at is number);
    }

    match /tournaments/{id} { allow read: if true; allow write: if isAdmin(); }
    match /groups/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /teams/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /matches/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /players/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /events/{id}      { allow read: if true; allow write: if isAdmin(); }

    // صندوق الاقتراحات: الزائر يضيف فقط (بلا قراءة)، والمدير يقرأ ويحذف.
    match /suggestions/{id} {
      allow create: if isValidSuggestion();
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // المسجّلون: كل مستخدم ينشئ/يعدّل وثيقته الخاصّة عند التسجيل، والمدير يقرأ القائمة.
    match /users/{uid} {
      allow read: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['email', 'name', 'created_at'])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string && request.resource.data.name.size() <= 60;
      allow delete: if isOwner();
    }

    // المدراء: المالك وحده يعيّن/يزيل. ويُسمح للمستخدم بقراءة وثيقته هو فقط (لمعرفة حالته).
    match /admins/{email} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.token.email == email);
      allow write: if isOwner();
    }

    // أي مجموعة أخرى: ممنوعة افتراضياً
    match /{document=**} { allow read, write: if false; }
  }
}
