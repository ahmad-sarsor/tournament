rules_version = '2';

// ============================================================================
//  قواعد أمان Firestore — نموذج متعدّد المستأجرين (v2)
//
//  الأدوار:
//   • المالك (owner): مثبَّت أدناه (بحروف صغيرة). كل الصلاحيات + اعتماد الأعضاء
//     ومنح مدراء المنصّة.
//   • مدير منصّة (platform admin): في admins/{email} — يدير كل التورنيرات.
//   • حساب فعّال: بريد مؤكّد، أو حساب بلا بريد وافق عليه المالك.
//   • مدير تورنير: بريده في admin_emails — يدير ذلك التورنير (عدا الطاقم والحذف).
//   • مسجِّل نتائج: بريده في scorer_emails — يعدّل نتائج/حالة المباريات
//     ويسجّل الأحداث (أهداف/بطاقات) واللاعبين الجدد فقط.
//
//  🔐 الحساب ذو البريد يتفعّل فقط بعد تأكيد البريد. الحساب بلا بريد يحتاج موافقة المالك.
//
//  القراءة عامّة (عرض للزوّار). النشر: Firebase Console → Firestore → Rules → Publish
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ✍️ بريد/بُرد «المالك» — بحروف صغيرة حصراً
    function ownerEmails() { return ['ahmad.kefah11sar@gmail.com']; }

    // بريد الطالب: يُعتمد فقط إن كان مُوثَّقاً، ويُعاد بحروف صغيرة — وإلا null
    function uemail() {
      return (request.auth != null
              && request.auth.token.get('email_verified', false) == true
              && request.auth.token.email != null)
        ? request.auth.token.email.lower() : null;
    }
    function isOwner() { return uemail() != null && uemail() in ownerEmails(); }
    function isPlatformAdmin() {
      return isOwner()
        || (uemail() != null && exists(/databases/$(database)/documents/admins/$(uemail())));
    }
    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function approvedUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).get('approved', false) == true;
    }
    function activeAccount() {
      return uemail() != null || approvedUser();
    }
    function isMember() {
      return isPlatformAdmin() || activeAccount()
        || (uemail() != null && exists(/databases/$(database)/documents/members/$(uemail())));
    }

    // مالك التورنير (d = بيانات التورنير)
    function isTOwner(d) {
      return (request.auth != null && d.get('owner_uid', '') == request.auth.uid)
        || (uemail() != null && d.get('owner_email', '').lower() == uemail());
    }
    // إدارة تورنير: منصّة، أو مالكه، أو مدير معيّن فيه
    function canManageT(d) {
      return isPlatformAdmin() || isTOwner(d)
        || (uemail() != null && uemail() in d.get('admin_emails', []));
    }
    // تسجيل نتائج: كل من يدير + المسجّلون المعيَّنون
    function canScoreT(d) {
      return canManageT(d)
        || (uemail() != null && uemail() in d.get('scorer_emails', []));
    }
    function tData(tid) {
      return get(/databases/$(database)/documents/tournaments/$(tid)).data;
    }
    function tExists(tid) {
      return tid is string && exists(/databases/$(database)/documents/tournaments/$(tid));
    }
    function parentManages(tid) { return tExists(tid) && canManageT(tData(tid)); }
    function parentScores(tid)  { return tExists(tid) && canScoreT(tData(tid)); }

    // مسابقة التوقّعات: صلاحية الإدارة مشتقّة من التورنير الأب
    function pcomp(cid)       { return get(/databases/$(database)/documents/pcomps/$(cid)).data; }
    function pcompExists(cid) { return cid is string && exists(/databases/$(database)/documents/pcomps/$(cid)); }
    function matchDoc(mid)    { return get(/databases/$(database)/documents/matches/$(mid)).data; }
    function matchExists(mid) { return mid is string && exists(/databases/$(database)/documents/matches/$(mid)); }
    // مالك الطلب
    function isSelf(id) { return request.auth != null && request.auth.uid == id; }
    // حساب منصة فعّال: بريد مؤكّد أو موافقة المالك لحساب بلا بريد
    function isPlatformAccount() { return activeAccount(); }

    // المفاتيح التي مسّها التعديل الحالي (للـ update فقط)
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function changed(k) { return changedKeys().hasAny([k]); }

    // فحوصات قيم عامّة (تتسامح مع الحقل الغائب)
    function okStr(v, mx) { return v is string && v.size() >= 1 && v.size() <= mx; }
    function okOptStr(d, k, mx) {
      return !(k in d) || d[k] == null || (d[k] is string && d[k].size() <= mx);
    }
    function okOptInt(d, k, mn, mx) {
      return !(k in d) || (d[k] is int && d[k] >= mn && d[k] <= mx);
    }
    function okNullInt(d, k, mn, mx) {
      return !(k in d) || d[k] == null || (d[k] is int && d[k] >= mn && d[k] <= mx);
    }
    function okOptNum(d, k) { return !(k in d) || d[k] is number; }
    function okEmailList(d, k) { return !(k in d) || (d[k] is list && d[k].size() <= 30); }

    // اقتراح صالح للإضافة من الزائر (بلا تسجيل)
    function isValidSuggestion() {
      let d = request.resource.data;
      return d.keys().hasOnly(['text', 'name', 'context', 'created_at'])
        && d.text is string && d.text.size() >= 1 && d.text.size() <= 1000
        && (!('name' in d)    || (d.name is string && d.name.size() <= 80))
        && (!('context' in d) || (d.context is string && d.context.size() <= 200))
        && (!('created_at' in d) || d.created_at is number);
    }

    // ---- البطولات ----------------------------------------------------------
    function tournamentKeys() {
      return ['name', 'description', 'status', 'start_date', 'end_date',
              'qualifiers_per_group', 'win_points', 'draw_points', 'loss_points',
              'owner_email', 'owner_uid', 'admin_emails', 'scorer_emails', 'sort_order', 'created_at'];
    }
    function tournamentValuesOk(d) {
      return okStr(d.get('name', ''), 120)
        && okOptStr(d, 'description', 1000)
        && (!('status' in d) || d.status in ['upcoming', 'active', 'finished'])
        && okOptStr(d, 'start_date', 20) && okOptStr(d, 'end_date', 20)
        && okOptInt(d, 'qualifiers_per_group', 0, 64)
        && okOptInt(d, 'win_points', 0, 100)
        && okOptInt(d, 'draw_points', 0, 100)
        && okOptInt(d, 'loss_points', 0, 100)
        && (!('owner_email' in d) || okStr(d.owner_email, 254))
        && (!('owner_uid' in d) || okStr(d.owner_uid, 128))
        && okEmailList(d, 'admin_emails') && okEmailList(d, 'scorer_emails')
        && okOptNum(d, 'sort_order') && okOptNum(d, 'created_at');
    }

    match /tournaments/{id} {
      allow read: if true;
      // ينشئها عضو معتمَد ويضع نفسه مالكاً (البريد بحروف صغيرة)
      allow create: if isMember()
        && request.resource.data.keys().hasOnly(tournamentKeys())
        && tournamentValuesOk(request.resource.data)
        && request.resource.data.get('owner_uid', '') == request.auth.uid
        && (uemail() == null || request.resource.data.get('owner_email', '') == uemail());
      // التعديل: مدير التورنير فأعلى. المالك لا يتغيّر (إلا بيد مدير المنصّة
      // لإنقاذ تورنيرات قديمة بلا مالك)، وقائمتا الطاقم لا يعدّلهما
      // إلا مالك التورنير أو مدير المنصّة (لا مدراء التورنير).
      allow update: if canManageT(resource.data)
        && changedKeys().hasOnly(tournamentKeys())
        && tournamentValuesOk(request.resource.data)
        && (!changed('owner_email') || isPlatformAdmin())
        && ((!changed('admin_emails') && !changed('scorer_emails'))
            || isPlatformAdmin() || isTOwner(resource.data));
      allow delete: if isPlatformAdmin() || isTOwner(resource.data);
    }

    // ---- بيانات التورنير (تُقيَّد بصلاحية التورنير الأب عبر tournament_id) ----

    function groupValuesOk(d) {
      return okStr(d.get('name', ''), 80) && okOptNum(d, 'sort_order');
    }
    match /groups/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['tournament_id', 'name', 'sort_order'])
        && groupValuesOk(request.resource.data)
        && parentManages(request.resource.data.tournament_id);
      allow update: if parentManages(resource.data.tournament_id)
        && changedKeys().hasOnly(['name', 'sort_order'])
        && groupValuesOk(request.resource.data);
      allow delete: if parentManages(resource.data.tournament_id);
    }

    function teamValuesOk(d) {
      return okStr(d.get('name', ''), 80)
        && (!('group_id' in d) || d.group_id == null || d.group_id is string)
        && okOptNum(d, 'sort_order');
    }
    match /teams/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['tournament_id', 'group_id', 'name', 'sort_order'])
        && teamValuesOk(request.resource.data)
        && parentManages(request.resource.data.tournament_id);
      allow update: if parentManages(resource.data.tournament_id)
        && changedKeys().hasOnly(['group_id', 'name', 'sort_order'])
        && teamValuesOk(request.resource.data);
      allow delete: if parentManages(resource.data.tournament_id);
    }

    function playerValuesOk(d) {
      return okStr(d.get('name', ''), 80)
        && (!('team_id' in d) || d.team_id is string)
        && okNullInt(d, 'number', 0, 999)
        && (!('role' in d) || d.role in ['player', 'coach', 'management'])
        && okOptNum(d, 'sort_order');
    }
    match /players/{id} {
      allow read: if true;
      // الإنشاء متاح للمسجِّل أيضاً (إضافة لاعب سريعة من شاشة المباراة المباشرة)
      allow create: if request.resource.data.keys().hasOnly(['tournament_id', 'team_id', 'name', 'number', 'role', 'sort_order'])
        && playerValuesOk(request.resource.data)
        && request.resource.data.team_id is string
        && parentScores(request.resource.data.tournament_id);
      allow update: if parentManages(resource.data.tournament_id)
        && changedKeys().hasOnly(['name', 'number', 'role', 'sort_order'])
        && playerValuesOk(request.resource.data);
      allow delete: if parentManages(resource.data.tournament_id);
    }

    function matchKeys() {
      return ['tournament_id', 'group_id', 'round', 'home_team_id', 'away_team_id',
              'match_date', 'match_time', 'status', 'home_score', 'away_score',
              'sort_order', 'live_started_at', 'stage', 'bracket_pos', 'locks_at'];
    }
    function matchValuesOk(d) {
      return (!('status' in d) || d.status in ['scheduled', 'live', 'finished'])
        && okNullInt(d, 'home_score', 0, 999) && okNullInt(d, 'away_score', 0, 999)
        && (!('group_id' in d) || d.group_id == null || d.group_id is string)
        && (!('home_team_id' in d) || d.home_team_id == null || d.home_team_id is string)
        && (!('away_team_id' in d) || d.away_team_id == null || d.away_team_id is string)
        && okOptStr(d, 'match_date', 20) && okOptStr(d, 'match_time', 20)
        && okOptInt(d, 'round', 0, 999)
        && okOptNum(d, 'sort_order')
        && (!('stage' in d) || d.stage in ['group', 'knockout'])
        && okOptInt(d, 'bracket_pos', 0, 999)
        && (!('live_started_at' in d) || d.live_started_at == null || d.live_started_at is number)
        && (!('locks_at' in d) || d.locks_at == null || d.locks_at is number);
    }
    // ما يُسمح لمسجِّل النتائج بتغييره في المباراة
    function scorerMatchKeys() { return ['home_score', 'away_score', 'status', 'live_started_at']; }

    match /matches/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(matchKeys())
        && matchValuesOk(request.resource.data)
        && parentManages(request.resource.data.tournament_id);
      // مدير: كل الحقول (دون نقل المباراة لتورنير آخر) · مسجِّل: النتيجة والحالة فقط
      allow update: if matchValuesOk(request.resource.data)
        && (
          (parentManages(resource.data.tournament_id)
            && changedKeys().hasOnly(['group_id', 'round', 'home_team_id', 'away_team_id',
                 'match_date', 'match_time', 'status', 'home_score', 'away_score',
                 'sort_order', 'live_started_at', 'stage', 'bracket_pos', 'locks_at']))
          ||
          (parentScores(resource.data.tournament_id)
            && changedKeys().hasOnly(scorerMatchKeys()))
        );
      allow delete: if parentManages(resource.data.tournament_id);
    }

    function eventValuesOk(d) {
      return (!('type' in d) || d.type in ['goal', 'yellow', 'red'])
        && (!('player_id' in d) || d.player_id == null || d.player_id is string)
        && (!('team_id' in d) || d.team_id is string)
        && (!('match_id' in d) || d.match_id is string)
        && okNullInt(d, 'minute', 0, 300)
        && okOptNum(d, 'created_at');
    }
    match /events/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['tournament_id', 'match_id', 'team_id', 'player_id', 'type', 'minute', 'created_at'])
        && eventValuesOk(request.resource.data)
        && request.resource.data.match_id is string
        && request.resource.data.team_id is string
        && parentScores(request.resource.data.tournament_id);
      // التعديل الوحيد المسموح: فكّ ربط لاعب محذوف (player_id → null) — للمدير
      allow update: if parentManages(resource.data.tournament_id)
        && changedKeys().hasOnly(['player_id'])
        && request.resource.data.player_id == null;
      allow delete: if parentScores(resource.data.tournament_id);
    }

    // ---- صندوق الاقتراحات ---------------------------------------------------
    match /suggestions/{id} {
      allow create: if isValidSuggestion();
      allow read, delete: if isPlatformAdmin();
      allow update: if false;
    }

    // ---- المسجّلون: بريد مؤكّد أو اسم مستخدم بلا بريد بانتظار موافقة المالك ----
    function userKeys() {
      return ['email', 'auth_email', 'username', 'name', 'created_at', 'verified', 'approved', 'no_email'];
    }
    function userValuesOk(d) {
      return d.get('email', '') is string && d.get('email', '').size() <= 254
        && d.get('auth_email', '') is string && d.get('auth_email', '').size() <= 254
        && (!('username' in d) || (d.username is string && d.username.size() >= 3 && d.username.size() <= 24))
        && d.get('name', '') is string && d.get('name', '').size() <= 60
        && d.get('verified', false) is bool
        && d.get('approved', false) is bool
        && d.get('no_email', false) is bool
        && okOptNum(d, 'created_at');
    }
    match /users/{userId} {
      allow read: if isPlatformAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(userKeys())
        && userValuesOk(request.resource.data)
        && request.resource.data.get('username', '') is string
        && request.resource.data.auth_email == request.auth.token.email.lower()
        && request.resource.data.approved == (uemail() != null);
      allow update: if (
          request.auth != null && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(userKeys())
          && changedKeys().hasOnly(['email', 'auth_email', 'name', 'verified', 'approved', 'no_email'])
          && userValuesOk(request.resource.data)
          && request.resource.data.auth_email == request.auth.token.email.lower()
          && (!changed('approved') || (uemail() != null && request.resource.data.approved == true))
        )
        || (isOwner()
          && changedKeys().hasOnly(['approved'])
          && request.resource.data.approved is bool);
      allow delete: if isOwner();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid', 'username', 'auth_email', 'email', 'created_at'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username
        && username.matches('^[a-z0-9_]{3,24}$')
        && request.resource.data.auth_email == request.auth.token.email.lower()
        && (!('email' in request.resource.data) || request.resource.data.email == null || request.resource.data.email is string)
        && okOptNum(request.resource.data, 'created_at')
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if false;
    }

    // ---- الأعضاء المعتمَدون (يُنشئون تورنيرات) — المالك وحده يعتمد -------------
    match /members/{addr} {
      allow read: if isPlatformAdmin() || (uemail() != null && uemail() == addr);
      allow create, update: if isOwner()
        && addr == addr.lower()
        && request.resource.data.keys().hasOnly(['email', 'added_at'])
        && request.resource.data.get('email', '') == addr
        && request.resource.data.get('added_at', 0) is number;
      allow delete: if isOwner();
    }

    // ---- مدراء المنصّة (كل الصلاحيات) — المالك وحده يمنح ----------------------
    match /admins/{addr} {
      allow read: if isPlatformAdmin() || (uemail() != null && uemail() == addr);
      allow create, update: if isOwner()
        && addr == addr.lower()
        && request.resource.data.keys().hasOnly(['email', 'added_at'])
        && request.resource.data.get('email', '') == addr
        && request.resource.data.get('added_at', 0) is number;
      allow delete: if isOwner();
    }

    // ---- مسابقة التوقّعات: المسابقات (pcomps) -------------------------------
    function pcompKeys() {
      return ['tournament_id', 'title', 'description', 'status', 'owner_email',
              'pts_exact', 'pts_diff', 'pts_outcome', 'winners_count', 'prizes',
              'predictions_open', 'created_at', 'sort_order'];
    }
    function pcompValuesOk(d) {
      return okStr(d.get('title', ''), 120)
        && okOptStr(d, 'description', 1000)
        && (!('status' in d) || d.status in ['draft', 'open', 'closed', 'finished'])
        && (!('predictions_open' in d) || d.predictions_open is bool)
        && okOptInt(d, 'pts_exact', 0, 1000)
        && okOptInt(d, 'pts_diff', 0, 1000)
        && okOptInt(d, 'pts_outcome', 0, 1000)
        && okOptInt(d, 'winners_count', 0, 100)
        && (!('prizes' in d) || (d.prizes is list && d.prizes.size() <= 100))
        && (!('owner_email' in d) || okStr(d.owner_email, 254))
        && okOptNum(d, 'sort_order') && okOptNum(d, 'created_at');
    }
    match /pcomps/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(pcompKeys())
        && pcompValuesOk(request.resource.data)
        && request.resource.data.tournament_id is string
        && parentManages(request.resource.data.tournament_id)
        && (uemail() == null || request.resource.data.get('owner_email', '') == uemail());
      allow update: if parentManages(resource.data.tournament_id)
        && request.resource.data.keys().hasOnly(pcompKeys())
        && pcompValuesOk(request.resource.data)
        && request.resource.data.tournament_id == resource.data.tournament_id;
      allow delete: if parentManages(resource.data.tournament_id);
    }

    // ---- المتوقّعون: اسم الحساب العامّ (للترتيب) — المشاركة بحساب منصة فقط ----
    //  التسجيل الجديد لا يقبل أسماء عابرة أو حسابات مجهولة: يجب أن يكون uid
    //  هو uid حساب Firebase ببريد مؤكّد، و verified=true من البداية.
    function predictorValuesOk(d) {
      return okStr(d.get('name', ''), 60)
        && d.get('competition_id', '') is string
        && d.get('tournament_id', '') is string
        && d.get('uid', '') is string
        && okOptNum(d, 'created_at');
    }
    // التسجيل متاح فقط والمسابقة «مفتوحة»، وضمن نفس التورنير
    function joinOpen(cid, tid) {
      return pcompExists(cid) && pcomp(cid).status == 'open' && pcomp(cid).tournament_id == tid;
    }
    match /predictors/{id} {
      allow read: if true;
      allow create: if isSelf(request.resource.data.uid)
        && isPlatformAccount()
        && request.resource.data.keys().hasOnly(['competition_id', 'tournament_id', 'uid', 'name', 'verified', 'created_at'])
        && ('verified' in request.resource.data) && request.resource.data.verified is bool
        && request.resource.data.verified == true
        && predictorValuesOk(request.resource.data)
        && joinOpen(request.resource.data.competition_id, request.resource.data.tournament_id);
      // صاحبه يعدّل اسمه فقط · مدير المنصّة يعتمد المشارك المنتظر (verified → true)
      // · منظّم التورنير يعدّل الاسم و«تسوية النقاط» (points_adj تُضاف لمجموع نقاطه)
      allow update: if (isSelf(resource.data.uid) && isPlatformAccount()
          && changedKeys().hasOnly(['name'])
          && okStr(request.resource.data.get('name', ''), 60))
        || (isPlatformAdmin()
          && changedKeys().hasOnly(['verified'])
          && request.resource.data.verified == true)
        || (parentManages(resource.data.tournament_id)
          && changedKeys().hasOnly(['name', 'points_adj'])
          && okStr(request.resource.data.get('name', ''), 60)
          && (!('points_adj' in request.resource.data)
              || (request.resource.data.points_adj is int
                  && request.resource.data.points_adj >= -9999
                  && request.resource.data.points_adj <= 9999)));
      allow delete: if isSelf(resource.data.uid) || parentManages(resource.data.tournament_id);
    }

    // ---- تواصل المتوقّع (هاتف/بريد/عمر) — خاصّ: يقرؤه صاحبه أو منظّم التورنير ----
    // فحوص الأنواع والأطوال فقط (الهاتف اختياري، والبريد يأتي من حساب المنصّة)
    function contactFieldsOk(d) {
      return d.get('competition_id', '') is string
        && d.get('tournament_id', '') is string
        && d.get('uid', '') is string
        && (!('phone' in d) || d.phone == null || (d.phone is string && d.phone.size() >= 3 && d.phone.size() <= 40))
        && (!('email' in d) || d.email == null || (d.email is string && d.email.size() >= 3 && d.email.size() <= 120))
        && (!('age' in d) || d.age == null || (d.age is int && d.age >= 3 && d.age <= 120))
        && (!('phone_verified' in d) || d.phone_verified is bool)
        && okOptNum(d, 'created_at');
    }
    // حقل قديم: لا يُدَّعى «هاتف موثّق» إلا إن طابق الرقم هاتف توكن Firebase نفسه
    function phoneClaimOk(d) {
      return d.get('phone_verified', false) == false
        || (request.auth != null
            && request.auth.token.get('phone_number', '') == d.get('phone', ''));
    }
    function contactKeys() {
      return ['competition_id', 'tournament_id', 'uid', 'phone', 'email', 'age', 'phone_verified', 'created_at'];
    }
    match /predictorContacts/{id} {
      // isPlatformAdmin أولاً: شرط بلا اعتماد على الوثيقة — يجعل استعلامات القائمة
      // قابلة للإثبات لمدير المنصّة مباشرة (قواعد القوائم تُقيَّم من شكل الاستعلام)
      allow read: if isPlatformAdmin() || isSelf(resource.data.uid) || parentManages(resource.data.tournament_id);
      // صاحبها عند الانضمام · أو المنظّم يستكمل وثيقة ناقصة لمشارك (بلا ادّعاء توثيق)
      allow create: if (isSelf(request.resource.data.uid) && isPlatformAccount()
          && request.resource.data.keys().hasOnly(contactKeys())
          && contactFieldsOk(request.resource.data)
          && phoneClaimOk(request.resource.data)
          && joinOpen(request.resource.data.competition_id, request.resource.data.tournament_id))
        || (parentManages(request.resource.data.tournament_id)
          && request.resource.data.keys().hasOnly(contactKeys())
          && contactFieldsOk(request.resource.data)
          && request.resource.data.get('phone_verified', false) == false);
      // صاحبها يعدّلها (مع شرط التوثيق) · المنظّم يعدّلها لكن لا يمنح «موثّق» —
      // وتغيير الرقم يُلزمه إسقاط شارة التوثيق (يفعله الكود تلقائياً)
      allow update: if (isSelf(resource.data.uid) && isPlatformAccount()
          && changedKeys().hasOnly(['phone', 'email', 'age', 'phone_verified'])
          && contactFieldsOk(request.resource.data)
          && phoneClaimOk(request.resource.data))
        || (parentManages(resource.data.tournament_id)
          && changedKeys().hasOnly(['phone', 'email', 'age', 'phone_verified'])
          && contactFieldsOk(request.resource.data)
          && (!changed('phone_verified') || request.resource.data.phone_verified == false)
          && (!changed('phone') || request.resource.data.get('phone_verified', false) == false));
      allow delete: if isSelf(resource.data.uid) || parentManages(resource.data.tournament_id);
    }

    // ---- التوقّعات — يكتبها صاحبها فقط، وتُقفل فور بدء المباراة ----------------
    function predictionValuesOk(d) {
      return d.get('competition_id', '') is string
        && d.get('tournament_id', '') is string
        && d.get('match_id', '') is string
        && d.get('uid', '') is string
        && d.get('home', -1) is int && d.get('home', -1) >= 0 && d.get('home', -1) <= 99
        && d.get('away', -1) is int && d.get('away', -1) >= 0 && d.get('away', -1) <= 99
        && okOptNum(d, 'created_at');
    }
    // يُسمح بالتوقّع إن قبلت المسابقة الإدخال، والمباراة لم تبدأ (status) ولم يحلّ موعدها (locks_at)
    function predEntryAllowed(d) {
      return pcompExists(d.competition_id)
        && pcomp(d.competition_id).status in ['open', 'closed']
        && pcomp(d.competition_id).get('predictions_open', true) == true
        && pcomp(d.competition_id).tournament_id == d.tournament_id
        // لا يوقّع إلا مشارك مسجَّل بحساب منصة وموثَّق في هذه المسابقة
        && exists(/databases/$(database)/documents/predictors/$(d.competition_id + '__' + d.uid))
        && get(/databases/$(database)/documents/predictors/$(d.competition_id + '__' + d.uid))
             .data.get('verified', true) == true
        && matchExists(d.match_id)
        && matchDoc(d.match_id).status == 'scheduled'
        && matchDoc(d.match_id).tournament_id == d.tournament_id
        && (matchDoc(d.match_id).get('locks_at', null) == null
            || request.time.toMillis() < matchDoc(d.match_id).get('locks_at', 0));
    }
    match /predictions/{id} {
      allow read: if true;
      allow create: if isSelf(request.resource.data.uid) && isPlatformAccount()
        && request.resource.data.keys().hasOnly(['competition_id', 'tournament_id', 'match_id', 'uid', 'home', 'away', 'created_at'])
        && predictionValuesOk(request.resource.data)
        && predEntryAllowed(request.resource.data);
      allow update: if isSelf(resource.data.uid) && isPlatformAccount()
        && changedKeys().hasOnly(['home', 'away', 'created_at'])
        && predictionValuesOk(request.resource.data)
        && predEntryAllowed(request.resource.data);
      allow delete: if isSelf(resource.data.uid) || parentManages(resource.data.tournament_id);
    }

    // أي مجموعة أخرى: ممنوعة افتراضياً
    match /{document=**} { allow read, write: if false; }
  }
}
